<?xml version="1.0" encoding="UTF-8"?>
<!-- roj-keymap (Windows / Linux / VDI). Parent: default Win/Linux keymap.
     Chords use only Ctrl/Alt/Shift (never Win) so they are byte-identical to
     the macOS file and survive Citrix Scancode mode. Do NOT hand-edit while
     the IDE is running - it will be overwritten on exit. See intellij/README.md. -->
<keymap version="1" name="roj-keymap" parent="$default">
  <!-- ===== TIER 0: Ctrl-based, already 2-key (Part 3 parity + close tab) ===== -->
  <action id="ActivateProjectToolWindow">
    <keyboard-shortcut first-keystroke="alt 1" />
  </action>
  <action id="ActivateVersionControlToolWindow">
    <keyboard-shortcut first-keystroke="alt 9" />
  </action>
  <action id="CloseContent">
    <keyboard-shortcut first-keystroke="ctrl W" />
  </action>
  <action id="Find">
    <keyboard-shortcut first-keystroke="ctrl F" />
  </action>
  <action id="FindInPath">
    <keyboard-shortcut first-keystroke="shift ctrl F" />
  </action>
  <action id="GotoDeclaration">
    <keyboard-shortcut first-keystroke="ctrl B" />
  </action>

  <!-- ===== TIER 1: bare Alt+<key>, 2-key, high frequency ===== -->
  <action id="ActivateTerminalToolWindow">
    <keyboard-shortcut first-keystroke="alt T" />
  </action>
  <action id="Back">
    <keyboard-shortcut first-keystroke="ctrl alt LEFT" />
  </action>
  <action id="CompileDirty">
    <keyboard-shortcut first-keystroke="alt B" />
  </action>
  <action id="Debug">
    <keyboard-shortcut first-keystroke="alt X" />
  </action>
  <action id="EditorLeft">
    <keyboard-shortcut first-keystroke="LEFT" />
  </action>
  <action id="EditorRight">
    <keyboard-shortcut first-keystroke="RIGHT" />
  </action>
  <action id="EditorSelectWord">
    <keyboard-shortcut first-keystroke="alt UP" />
  </action>
  <action id="EditorUnSelectWord">
    <keyboard-shortcut first-keystroke="alt DOWN" />
  </action>
  <action id="EvaluateExpression">
    <keyboard-shortcut first-keystroke="alt E" />
  </action>
  <action id="FindUsages">
    <keyboard-shortcut first-keystroke="alt U" />
  </action>
  <action id="Forward">
    <keyboard-shortcut first-keystroke="ctrl alt RIGHT" />
  </action>
  <action id="GotoClass">
    <keyboard-shortcut first-keystroke="alt C" />
  </action>
  <action id="GotoFile">
    <keyboard-shortcut first-keystroke="alt F" />
  </action>
  <action id="GotoSymbol">
    <keyboard-shortcut first-keystroke="alt S" />
  </action>
  <action id="NewElement">
    <keyboard-shortcut first-keystroke="alt N" />
  </action>
  <action id="NextTab">
    <keyboard-shortcut first-keystroke="alt PAGE_DOWN" />
  </action>
  <action id="PreviousTab">
    <keyboard-shortcut first-keystroke="alt PAGE_UP" />
  </action>
  <action id="RenameElement">
    <keyboard-shortcut first-keystroke="alt R" />
  </action>
  <action id="Run">
    <keyboard-shortcut first-keystroke="alt W" />
  </action>
  <action id="SelectIn">
    <keyboard-shortcut first-keystroke="alt I" />
  </action>
  <action id="StepInto">
    <keyboard-shortcut first-keystroke="alt G" />
  </action>
  <action id="StepOut">
    <keyboard-shortcut first-keystroke="alt Q" />
  </action>
  <action id="StepOver">
    <keyboard-shortcut first-keystroke="alt D" />
  </action>
  <action id="ToggleLineBreakpoint">
    <keyboard-shortcut first-keystroke="alt K" />
  </action>

  <!-- ===== TIER 2: leader, Alt+Minus then a key (was Ctrl+Alt+; ) ===== -->
  <action id="ChangeSignature">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="C" />
  </action>
  <action id="ChooseDebugConfiguration">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="shift X" />
  </action>
  <action id="ChooseRunConfiguration">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="shift W" />
  </action>
  <action id="EditSourceInNewWindow">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="O" />
  </action>
  <action id="EditorDeleteLine">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="BACK_SPACE" />
  </action>
  <action id="FileStructurePopup">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="S" />
  </action>
  <action id="Generate">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="G" />
  </action>
  <action id="GotoNextError">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="E" />
  </action>
  <action id="GotoPreviousError">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="shift E" />
  </action>
  <action id="HideAllWindows">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="J" />
  </action>
  <action id="JumpToLastWindow">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="W" />
  </action>
  <action id="Move">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="M" />
  </action>
  <action id="NextDiff">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="N" />
  </action>
  <action id="PreviousDiff">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="shift N" />
  </action>
  <action id="QuickJavaDoc">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="D" />
  </action>
  <action id="Refactorings.QuickListPopupAction">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="Q" />
  </action>
  <action id="Resume">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="R" />
  </action>
  <action id="RunToCursor">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="U" />
  </action>
  <action id="SelectNextOccurrence">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="V" />
  </action>
  <action id="ShowBookmarks">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="shift B" />
  </action>
  <action id="ShowErrorDescription">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="shift D" />
  </action>
  <action id="ShowExecutionPoint">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="P" />
  </action>
  <action id="SmartStepInto">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="A" />
  </action>
  <action id="Stop">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="X" />
  </action>
  <action id="ToggleBookmark">
    <keyboard-shortcut first-keystroke="alt MINUS" second-keystroke="B" />
  </action>

  <!-- Empty self-closing <action id="X"/> = unbind: the real keymap-scheme
       XML dialect has no remove="true" attribute (that only exists for a
       different XML dialect - plugin.xml action registration - and is
       silently ignored here). Each <action> element REPLACES that id's
       whole shortcut list for THIS keymap; an empty list fully unbinds it.
       Only entries still needed by a chord we actually use survive here;
       the old hot-set's inherited-conflict unbinds no longer apply since
       Ctrl+Alt+<letter> isn't used by anything except Back/Forward's arrows
       (which never collided on Windows - $default already owns that chord
       for those actions). -->
  <action id="EditorContextInfo" />
  <action id="MethodDown" />
  <action id="MethodUp" />
  <action id="ShowContent" />
  <action id="ShowSearchHistory" />
  <action id="UsageFiltering.WriteAccess" />
</keymap>
